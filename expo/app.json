{
  "expo": {
    "name": "Loan Agent",
    "slug": "loanagent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "loanagent",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050807"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rork.loanagent",
      "infoPlist": {
        "NSCameraUsageDescription": "Loan Agent uses the camera to scan and upload loan documents.",
        "NSMicrophoneUsageDescription": "Loan Agent uses the microphone for voice input to your AI Loan Agent."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#003D2B"
      },
      "package": "app.rork.loanagent",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Loan Agent uses the camera to scan and upload loan documents.",
          "microphonePermission": "Loan Agent uses the microphone for voice input to your AI Loan Agent.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
